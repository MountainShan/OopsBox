FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8

# ── System packages ──
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq build-essential procps tmux \
    python3 python3-pip python3-venv \
    ca-certificates openssl \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js + Claude CLI ──
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g @anthropic-ai/claude-code && \
    npm cache clean --force && \
    rm -rf /var/lib/apt/lists/*

# ── Agent user (UID matches host for bind mount permissions) ──
ARG AGENT_UID=1000
RUN useradd -m -s /bin/bash -u $AGENT_UID agent

# ── Claude loop script ──
COPY bin/claude-loop.sh /usr/local/bin/claude-loop.sh
RUN chmod +x /usr/local/bin/claude-loop.sh

USER agent
WORKDIR /workspace

CMD ["claude-loop.sh"]
