#!/usr/bin/env bash
set -euo pipefail

case "${1:-help}" in
  otp)
    RESULT=$(curl -s -X POST http://localhost:5000/api/auth/otp)
    OTP=$(echo "$RESULT" | jq -r '.otp')
    EXP=$(echo "$RESULT" | jq -r '.expires_in')
    echo ""
    echo "  ╔═════════════════════════════╗"
    echo "  ║  OTP: $OTP                  ║"
    echo "  ║  Expires: $((EXP/60)) minutes           ║"
    echo "  ╚═════════════════════════════╝"
    echo ""
    ;;
  urls)
    IP=$(hostname -I | awk '{print $1}')
    TS_IP=$(tailscale ip -4 2>/dev/null || echo "n/a")
    echo ""
    echo "  LAN:        http://$IP/"
    echo "  Tailscale:  http://$TS_IP/"
    echo "  Code-Server: http://$IP/code-server/"
    echo "  System Term: http://$IP/system/term/"
    echo ""
    ;;
  status)
    RESULT=$(curl -s http://localhost:5000/api/system)
    CPU=$(echo "$RESULT" | jq -r '.cpu.percent')
    RAM=$(echo "$RESULT" | jq -r '.ram.percent')
    SWAP=$(echo "$RESULT" | jq -r '.swap.percent')
    DISK=$(echo "$RESULT" | jq -r '.disk.percent')
    echo "CPU: ${CPU}% | RAM: ${RAM}% | SWAP: ${SWAP}% | DISK: ${DISK}%"
    PROJS=$(curl -s http://localhost:5000/api/projects | jq -r '.projects[] | "\(.name) (\(.status))"' | tr '\n' ', ' | sed 's/, $//')
    echo "Projects: ${PROJS:-none}"
    ;;
  *)
    echo "oopsbox — I just wanted to code on iPad"
    echo ""
    echo "  oopsbox otp      generate login password"
    echo "  oopsbox urls     show all URLs"
    echo "  oopsbox status   system status"
    echo ""
    ;;
esac
